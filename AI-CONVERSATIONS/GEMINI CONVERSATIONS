def calculate_budget_runway(available_cash, total_spent):
    """
    Calculates the current financial surplus runway.
    """
    try:
        cash = float(available_cash)
        spent = float(total_spent)
        net = cash - spent
        return f"Calculated Status: Net balance remaining is exactly ${net:,.2f}."
    except Exception as e:
        return f"Error executing calculation tool: {str(e)}"

def calculate_savings_feasibility(salary, emergency_fund, secondary_target, total_expenses):
    """
    Calculates if a user's salary can support their combined monthly savings targets.
    """
    try:
        sal = float(salary)
        emg = float(emergency_fund)
        sec = float(secondary_target) if secondary_target else 0.0
        exp = float(total_expenses)
        
        disposable_cash = sal - exp
        total_needed_savings = emg + sec
        final_residual = disposable_cash - total_needed_savings
        
        if final_residual >= 0:
            return f"Feasibility Verified! You have a surplus of ${final_residual:,.2f} after meeting all savings goals."
        else:
            return f"Deficit Warning! You are short by ${abs(final_residual):,.2f} to meet your goals this month."
    except Exception as e:
        return f"Error executing savings feasibility tool: {str(e)}"


