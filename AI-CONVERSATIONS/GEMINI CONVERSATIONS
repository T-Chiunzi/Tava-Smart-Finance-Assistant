```python
def calculate_savings_buddy(salary, goal_name, goal_cost, expenses_dict, boost_percentage=0):
    """
    Your custom tool function. It takes numbers from the UI, 
    performs calculations, and returns a summary message.
    """
    # 1. Handle the savings boost percentage if selected
    # If a user wants to boost their savings by 10%, we increase their allocation target
    boost_factor = 1 + (boost_percentage / 100)
    
    # 2. Calculate Total Expenses and percentages
    total_expenses = sum(expenses_dict.values())
    leftover_income = salary - total_expenses
    
    # 3. Generate a dynamic breakdown string
    breakdown_report = "### Expense Breakdown:\n"
    for category, amount in expenses_dict.items():
        percentage_of_income = (amount / salary) * 100 if salary > 0 else 0
        breakdown_report += f"- **{category}**: ${amount:,.2f} ({percentage_of_income:.1f}% of income)\n"
    
    # 4. Calculate Timeline for the specific item (e.g., TV)
    # Let's say we advise saving 15% of their leftover income monthly, scaled by the boost
    monthly_savings_target = (leftover_income * 0.15) * boost_factor
    
    if monthly_savings_target <= 0:
        timeline_message = "⚠️ Based on your current expenses, you don't have enough remaining balance to save comfortably. Let's chat with the AI Coach to optimize your budget!"
    else:
        months_needed = goal_cost / monthly_savings_target
        timeline_message = f"🎯 To buy your **{goal_name}** (${goal_cost:,.2f}), if you save ${monthly_savings_target:,.2f} a month, you will hit your goal in **{months_needed:.1f} months**!"
        
    # Combine everything into a nice output report
    final_output = f"""
## 📊 Your Savings Buddy Dashboard Report

**Total Salary:** ${salary:,.2f}
**Total Expenses:** ${total_expenses:,.2f}
**Remaining Disposable Income:** ${leftover_income:,.2f}

{breakdown_report}

---
### 📅 Your Timeline Plan
{timeline_message}
"""
    return final_output

```

